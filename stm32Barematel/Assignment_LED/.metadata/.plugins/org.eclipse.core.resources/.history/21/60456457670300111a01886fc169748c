#include <stdint.h>
#include <stdio.h>
#include "stm32f446xx.h"
#include "stm32f446xx_gpio_driver.h"


#define LED_PIN         GPIO_PIN_NO_5      // Onboard LED (PA5)
#define BUTTON_PIN      GPIO_PIN_NO_13     // User button (PC13)
#define EXT_LED1_PIN    GPIO_PIN_NO_6      // External LED 1 (PA6)
#define EXT_LED2_PIN    GPIO_PIN_NO_7      // External LED 2 (PA7)

/* Simple busy-wait delay (~250 ms) */
void delay_250ms(void)
{
    for (volatile uint32_t i = 0; i < 420000; i++);
}

int main(void)
{
    GPIO_Handle_t GpioLed, GpioButton, GpioExtLed1, GpioExtLed2;

    /*  ONBOARD LED : PA5 */
    GpioLed.pGPIOx = GPIOA;
    GpioLed.GPIO_PinConfig.GPIO_PinNumber = LED_PIN;
    GpioLed.GPIO_PinConfig.GPIO_PinMode = GPIO_MODE_OUT;
    GpioLed.GPIO_PinConfig.GPIO_PinSpeed = GPIO_SPEED_MEDIUM;
    GpioLed.GPIO_PinConfig.GPIO_PinOPType = GPIO_OP_TYPE_PP;
    GpioLed.GPIO_PinConfig.GPIO_PinPuPdControl = GPIO_NO_PUPD;
    GPIO_Init(&GpioLed);

    /*  BUTTON : PC13  */
    GpioButton.pGPIOx = GPIOC;
    GpioButton.GPIO_PinConfig.GPIO_PinNumber = BUTTON_PIN;
    GpioButton.GPIO_PinConfig.GPIO_PinMode = GPIO_MODE_IN;
    GpioButton.GPIO_PinConfig.GPIO_PinSpeed = GPIO_SPEED_FAST;
    GpioButton.GPIO_PinConfig.GPIO_PinPuPdControl = GPIO_PIN_PU;
    GPIO_Init(&GpioButton);

    /* = EXTERNAL LED 1 : PA6 = */
    GpioExtLed1.pGPIOx = GPIOA;
    GpioExtLed1.GPIO_PinConfig.GPIO_PinNumber = EXT_LED1_PIN;
    GpioExtLed1.GPIO_PinConfig.GPIO_PinMode = GPIO_MODE_OUT;
    GpioExtLed1.GPIO_PinConfig.GPIO_PinSpeed = GPIO_SPEED_MEDIUM;
    GpioExtLed1.GPIO_PinConfig.GPIO_PinOPType = GPIO_OP_TYPE_PP;
    GpioExtLed1.GPIO_PinConfig.GPIO_PinPuPdControl = GPIO_NO_PUPD;
    GPIO_Init(&GpioExtLed1);

    /*EXTERNAL LED 2 : PA7 */
    GpioExtLed2.pGPIOx = GPIOA;
    GpioExtLed2.GPIO_PinConfig.GPIO_PinNumber = EXT_LED2_PIN;
    GpioExtLed2.GPIO_PinConfig.GPIO_PinMode = GPIO_MODE_OUT;
    GpioExtLed2.GPIO_PinConfig.GPIO_PinSpeed = GPIO_SPEED_MEDIUM;
    GpioExtLed2.GPIO_PinConfig.GPIO_PinOPType = GPIO_OP_TYPE_PP;
    GpioExtLed2.GPIO_PinConfig.GPIO_PinPuPdControl = GPIO_NO_PUPD;
    GPIO_Init(&GpioExtLed2);


    while (1)
    {
        /* -------- Task 1: Button toggles onboard LED -------- */
        if (GPIO_ReadFromInputPin(GPIOC, BUTTON_PIN) == 0)
        {
            GPIO_ToggleOutputPin(GPIOA, LED_PIN);
            delay_250ms();   // debounce
        }

        /* Task 2: Alternating external LEDs */
        GPIO_WriteToOutputPin(GPIOA, EXT_LED1_PIN, GPIO_PIN_SET);
        GPIO_WriteToOutputPin(GPIOA, EXT_LED2_PIN, GPIO_PIN_RESET);
        delay_250ms();

        GPIO_WriteToOutputPin(GPIOA, EXT_LED1_PIN, GPIO_PIN_RESET);
        GPIO_WriteToOutputPin(GPIOA, EXT_LED2_PIN, GPIO_PIN_SET);
        delay_250ms();
    }
}
